# Backend Environment Variables - Example
# Copy this to .env and fill in the values

# Database Configuration
# For development: sqlite:///dev.db
# For production: postgresql://user:password@host:port/dbname
DATABASE_URL=sqlite:///dev.db

# Authentication Tokens (comma-separated for multiple tokens)
# Leave empty to disable authentication for local development
INGEST_API_TOKENS=

# Search Cache TTL (in seconds)
SEARCH_CACHE_TTL_SECONDS=60

# Logging Level
# Options: DEBUG, INFO, WARNING, ERROR, CRITICAL
LOG_LEVEL=INFO
